# Application
TEMPINBOX_MASTER_KEY=change-me-to-a-secure-random-string
TEMPINBOX_SMTP_DOMAINS=["example.com"]
TEMPINBOX_SMTP_EXTERNAL_PORT=25
TEMPINBOX_MESSAGE_TTL_HOURS=72
TEMPINBOX_CLEANUP_INTERVAL_MINUTES=30
TEMPINBOX_RATE_LIMIT_PER_MINUTE=60
TEMPINBOX_MAX_EMAIL_SIZE=10485760

# PostgreSQL
POSTGRES_USER=tempinbox
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_DB=tempinbox

# Redis
REDIS_PASSWORD=change-me-to-a-different-secure-password

# Caddy (domain for automatic HTTPS via Let's Encrypt)
TEMPINBOX_API_DOMAIN=api.tempinbox.example.com
